@inject Microsoft.AspNetCore.Identity.SignInManager<Microsoft.AspNetCore.Identity.IdentityUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Website</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Website.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        #sidebar {
            width: 240px;
            min-width: 240px;
            transition: width 0.3s ease, min-width 0.3s ease, opacity 0.3s ease;
            overflow: hidden;
            background-color: #f8f9fa;
            padding: 1rem 0;
        }

        #sidebar.collapsed {
            width: 0;
            min-width: 0;
            opacity: 0;
            padding: 0;
        }

        #page-wrapper {
            display: flex;
            flex: 1;
        }

        #main-content {
            flex: 1;
            padding: 1rem;
            overflow-x: hidden;
        }
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        #toggleMenu {
            width: 24px;
            height: 24px;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-0">
            <div class="container-fluid">

                <!-- Sidebar toggle button -->
                <button class="btn btn-outline-primary me-2" id="sidebarToggleBtn" title="Afficher / cacher les catégories">
                    ☰
                </button>

                <!-- BRAND -->
                <a class="navbar-brand" asp-controller="Product" asp-action="Index">
                    <i class="fa-solid fa-store"></i> Shop</a>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <!-- LEFT MENU -->
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Product" asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Panier" asp-action="Index">
                                MonPanier
                            </a>
                        </li>

                        <!-- ADMIN MENU -->
                        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                   data-bs-toggle="dropdown"
                                   href="#"
                                   role="button"
                                   aria-haspopup="true"
                                   aria-expanded="false">
                                    Administration
                                </a>

                                <div class="dropdown-menu">

                                    <a class="dropdown-item"
                                       asp-controller="Admin"
                                       asp-action="CreateRole">
                                        Create Role
                                    </a>

                                    <div class="dropdown-divider"></div>

                                    <a class="dropdown-item"
                                       asp-controller="Admin"
                                       asp-action="ListRoles">
                                        List Roles
                                    </a>

                                </div>
                            </li>
                        }

                    </ul>

                    <!-- RIGHT MENU -->
                    <ul class="navbar-nav ms-auto">

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <form method="post" asp-controller="Account" asp-action="Logout">
                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="nav-link btn btn-link py-0"
                                            style="width:auto;">
                                        Logout @User.Identity.Name
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    Register
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- PAGE WRAPPER -->
    <div id="page-wrapper">

        <!-- SIDEBAR -->
        <aside id="sidebar">
            @await Html.PartialAsync("_CategoriesMenu", ViewData["Categories"])
        </aside>

        <!-- MAIN CONTENT -->
        <div id="main-content">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/CustomScript.js"></script>

    <script>
        // Toggle sidebar visibility
        document.getElementById('sidebarToggleBtn').addEventListener('click', function () {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('collapsed');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

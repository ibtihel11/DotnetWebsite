@model Website.ViewModels.EditRoleViewModel

<form asp-action="EditRole" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RoleName" />

    <div class="card">
        <div class="card-header">
            <h3>Manage Users in Role</h3>
        </div>

        <div class="card-body">
            @for (int i = 0; i < Model.Users.Count; i++)
            {
                <div class="form-check">
                    <input type="checkbox"
                           name="Users[@i].IsSelected"
                           value="true"
                           checked="@(Model.Users[i].IsSelected ? "checked" : null)"
                           class="form-check-input" />
                    <input type="hidden" name="Users[@i].UserId" value="@Model.Users[i].UserId" />
                    <input type="hidden" name="Users[@i].Email" value="@Model.Users[i].Email" />
                    <label class="form-check-label">
                        @Model.Users[i].Email
                    </label>
                </div>
            }
        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-3">
        Save Changes
    </button>
</form>
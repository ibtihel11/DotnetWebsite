@model Website.Models.Order
@{
    ViewData["Title"] = "Confirmation";
}

<div class="alert alert-success">
    <h2>Votre commande a été validée avec succès !</h2>
</div>

<p>
    Merci pour votre achat, <strong>@Model.CustomerName</strong> !
    Votre commande a bien été enregistrée.
</p>

<div class="card p-3">
    <h4>Récapitulatif de votre commande</h4>

    <p><strong>Numéro de commande :</strong> @Model.Id</p>
    <p><strong>Date :</strong> @Model.OrderDate.ToString("dd/MM/yyyy à HH:mm")</p>
    <p><strong>Montant total :</strong> @Model.TotalAmount €</p>
    <p><strong>Adresse de livraison :</strong> @Model.Address</p>

    <h5 class="mt-3">Articles commandés :</h5>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Produit</th>
                <th>Quantité</th>
                <th>Prix Unitaire</th>
                <th>Total Ligne</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Quantity</td>
                    <td>@item.Price €</td>
                    <td>@(item.Price * item.Quantity) €</td>
                </tr>
            }
        </tbody>
    </table>

    <p class="mt-2">
        <a class="btn btn-primary" asp-controller="Product" asp-action="Index">
            Continuer mes achats
        </a>
    </p>
</div>
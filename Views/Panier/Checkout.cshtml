@model Website.ViewModels.OrderViewModel
@{
    ViewData["Title"] = "CheckOut";
}

<h2>Passer la commande</h2>

<form method="post">
    @Html.AntiForgeryToken()

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Adresse de livraison :</label>
        <input type="text" name="Address" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Méthode de paiement :</label>
        <select name="PaymentMethod" class="form-select">
            <option value="Carte">Carte de crédit</option>
            <option value="PayPal">PayPal</option>
        </select>
    </div>

    <div class="mb-3">
        <strong>Montant total : @Model.TotalAmount €</strong>
    </div>

    {{!-- Hidden fields to pass cart items to POST --}}
    @for (int i = 0; i < Model.CartItems.Count; i++)
    {
        <input type="hidden" name="CartItems[@i].ProductName" value="@Model.CartItems[i].ProductName" />
        <input type="hidden" name="CartItems[@i].Quantity" value="@Model.CartItems[i].Quantity" />
        <input type="hidden" name="CartItems[@i].Price" value="@Model.CartItems[i].Price" />
    }

    <button type="submit" class="btn btn-success">Passer la commande</button>
</form>

<hr />

<h4>Votre panier</h4>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nom du produit</th>
            <th>Quantité</th>
            <th>Prix Unitaire</th>
            <th>Total Ligne</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.CartItems)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Quantity</td>
                <td>@item.Price €</td>
                <td>@(item.Price * item.Quantity) €</td>
            </tr>
        }
    </tbody>
</table>